# SafeAlert 환경변수 예시
# 이 파일을 복사해서 .env로 사용하세요
# cp .env.example .env

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# ── PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_USERNAME=safealert
DB_PASSWORD=your-db-password

# ── Google OAuth2 ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Kakao OAuth2 ────────────────────────────────
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ── Gmail SMTP (이메일 인증) ──────────────────────
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── 공공 API 키 ──────────────────────────────────
# 기상청 API (apis.data.go.kr 발급)
WEATHER_API_KEY=your-weather-api-key

# 행정안전부 재난문자 API (safetydata.go.kr 발급)
DISASTER_API_KEY=your-disaster-api-key

# 환경부 미세먼지 API (apis.data.go.kr 발급)
DUST_API_KEY=your-dust-api-key

# 행정안전부 법정동코드 API (apis.data.go.kr 발급)
REGION_API_KEY=your-region-api-key
