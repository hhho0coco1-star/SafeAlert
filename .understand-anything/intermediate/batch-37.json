    {
      "id": "file:api-gateway/src/main/java/com/safealert/gateway/ApiGatewayApplication.java",
      "type": "file",
      "name": "ApiGatewayApplication.java",
      "filePath": "api-gateway/src/main/java/com/safealert/gateway/ApiGatewayApplication.java",
      "summary": "Spring Boot API Gateway 서비스의 진입점으로, @SpringBootApplication 어노테이션을 통해 자동 구성과 컴포넌트 스캔을 활성화하고 애플리케이션을 시작한다.",
      "tags": ["entry-point", "spring-boot", "gateway"],
      "complexity": "simple"
    },
    {
      "id": "file:api-gateway/src/main/java/com/safealert/gateway/config/SecurityConfig.java",
      "type": "file",
      "name": "SecurityConfig.java",
      "filePath": "api-gateway/src/main/java/com/safealert/gateway/config/SecurityConfig.java",
      "summary": "Spring WebFlux Security 설정 클래스로, CSRF/HTTP Basic/Form Login을 비활성화하고 모든 요청을 허용하여 JWT 필터 기반 인증에 위임한다.",
      "tags": ["configuration", "security", "middleware"],
      "complexity": "simple",
      "languageNotes": "WebFlux 기반 리액티브 스택이므로 ServerHttpSecurity를 사용한다."
    },
    {
      "id": "file:api-gateway/src/main/java/com/safealert/gateway/filter/JwtAuthFilter.java",
      "type": "file",
      "name": "JwtAuthFilter.java",
      "filePath": "api-gateway/src/main/java/com/safealert/gateway/filter/JwtAuthFilter.java",
      "summary": "Spring Cloud Gateway의 전역 필터로, 모든 요청의 JWT 토큰을 검증하고 유효한 경우 X-User-Id 헤더를 추가하여 다운스트림 서비스로 전달한다.",
      "tags": ["middleware", "security", "api-handler", "authentication"],
      "complexity": "moderate",
      "languageNotes": "ReadOnlyHttpHeaders 제약을 피하기 위해 ServerHttpRequestDecorator 패턴을 사용하여 헤더를 불변성 위반 없이 변경한다."
    },
    {
      "id": "class:api-gateway/src/main/java/com/safealert/gateway/filter/JwtAuthFilter.java:JwtAuthFilter",
      "type": "class",
      "name": "JwtAuthFilter",
      "filePath": "api-gateway/src/main/java/com/safealert/gateway/filter/JwtAuthFilter.java",
      "lineRange": [27, 104],
      "summary": "GlobalFilter와 Ordered를 구현하는 JWT 인증 전역 필터 클래스로, 화이트리스트 경로 제외 후 Bearer 토큰을 파싱하여 인증을 처리한다.",
      "tags": ["middleware", "security", "authentication", "filter"],
      "complexity": "moderate"
    },
    {
      "id": "file:api-gateway/src/main/java/com/safealert/gateway/filter/RateLimitFilter.java",
      "type": "file",
      "name": "RateLimitFilter.java",
      "filePath": "api-gateway/src/main/java/com/safealert/gateway/filter/RateLimitFilter.java",
      "summary": "Redis를 활용하여 IP 기반으로 분당 60회 요청 제한을 적용하는 Spring Cloud Gateway 전역 필터이며, Redis 장애 시 제한을 우아하게 비활성화한다.",
      "tags": ["middleware", "rate-limiting", "redis", "api-handler"],
      "complexity": "moderate",
      "languageNotes": "ReactiveStringRedisTemplate을 사용하는 논블로킹 리액티브 구현이며, onErrorResume으로 Redis 장애 시 fail-open 전략을 적용한다."
    },
